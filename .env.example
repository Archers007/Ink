# Optional: lets the server proxy AI requests so the browser doesn't need an API key.
# Pick one provider. If neither is set, the UI falls back to "bring your own key".
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Port for the local server.
PORT=3000

# Cloudflare Tunnel token (for the `cloudflared` service in docker-compose).
# Get it from the Cloudflare Zero Trust dashboard. NEVER commit the real value.
CLOUDFLARED_TOKEN=
